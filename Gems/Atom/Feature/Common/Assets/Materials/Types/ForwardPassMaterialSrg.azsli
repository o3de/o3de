#pragma once 

#include <Atom/Features/SrgSemantics.azsli>

ShaderResourceGroup MaterialSrg : SRG_PerMaterial
{
    StructuredBuffer<MaterialParameters> m_materialParameters;

    Sampler m_sampler
    {
        AddressU = Wrap;
        AddressV = Wrap;
        MinFilter = Linear;
        MagFilter = Linear;
        MipFilter = Linear;
        MaxAnisotropy = 16;
    };

    Texture2D m_brdfMap;

    Sampler m_samplerBrdf
    {
        AddressU = Clamp;
        AddressV = Clamp;
        MinFilter = Linear;
        MagFilter = Linear;
        MipFilter = Linear;
    };
}

#include <Atom/Features/Bindless.azsli>
Texture2D asTexture(const int readIndex)
{
    return Bindless::GetTexture2D(readIndex);
}

MaterialParameters GetMaterialParameters()
{
    if (DrawSrg::m_materialInstanceId >= 0)
    {
        return MaterialSrg::m_materialParameters[DrawSrg::m_materialInstanceId];
    }
    else {
        return (MaterialParameters)0;
    }
}

sampler GetMaterialTextureSampler(/* TODO: sampler params */)
{
    return MaterialSrg::m_sampler;
}

